# Copy this file to .env.local and fill in values for local development
# .env.local is gitignored — never commit secrets

# URL of the Java Spring Boot backend
# In development: http://localhost:8080
# In production: https://<your-domain> (Nginx terminates TLS, proxies to :8080)
VITE_API_BASE_URL=http://localhost:8080

# Override tournament phase locally for dev/testing.
# Remove or leave unset to use the live phase from the backend.
# Valid values: PRE_TOURNAMENT | GROUP_STAGE | PRE_KNOCKOUT | KNOCKOUT
# VITE_DEV_PHASE=PRE_TOURNAMENT
